{
  "id": null,
  "uid": "rootlens-main",
  "title": "rootLens — System Overview",
  "tags": ["rootlens"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events Ingested (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(rootlens_events_ingested_total[5m]))",
          "legendFormat": "events"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Incidents Created (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "increase(rootlens_incidents_created_total[5m])",
          "legendFormat": "incidents"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "AI Analysis Success Rate",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rootlens_ai_analysis_result_total{success=\"true\"}) / sum(rootlens_ai_analysis_result_total) * 100",
          "legendFormat": "success %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "unit": "percent" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dedup Suppressed (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "increase(rootlens_incidents_dedup_suppressed_total[5m])",
          "legendFormat": "suppressed"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Events Ingested per Second (by type)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(type) (rate(rootlens_events_ingested_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "AI Analysis Latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(rootlens_ai_analysis_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(rootlens_ai_analysis_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Usage by Service",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(service) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
